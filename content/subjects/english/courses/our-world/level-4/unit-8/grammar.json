    {
      "id": "ow_l4_u8_g1_who_clauses",
      "type": "grammar",
      "subject": "english",
      "course": "our-world",
      "level": 4,
      "unit": 8,
      "component": "grammar-1",
      "lessonId": "ow-l4-u8-grammar-1",
      "lessonStatus": "draft",
      "tag": "OW4-U8-G1",
      "title": "Describing people with who",
      "shortName": "who clauses",
      "rule": "Use who in a sentence to give more information about people.",
      "pattern": "person + who + verb phrase",
      "chart": {
        "chartType": "grammar-reference-card",
        "tabs": [
          {
            "id": "notice",
            "label": "Notice",
            "title": "Two sentences can become one sentence with who.",
            "blocks": [
              {
                "type": "sentencePair",
                "before": [
                  "I have a classmate.",
                  "She likes math."
                ],
                "after": "I have a classmate who likes math."
              },
              {
                "type": "sentencePair",
                "before": [
                  "Mateo has two friends.",
                  "They play basketball."
                ],
                "after": "Mateo has two friends who play basketball."
              }
            ]
          },
          {
            "id": "pattern",
            "label": "Pattern",
            "title": "Use who after a person or people.",
            "blocks": [
              {
                "type": "pattern",
                "parts": [
                  "person",
                  "who",
                  "verb phrase"
                ]
              },
              {
                "type": "note",
                "text": "Who connects the person to extra information about that person."
              }
            ]
          },
          {
            "id": "examples",
            "label": "Examples",
            "title": "Workbook examples",
            "blocks": [
              {
                "type": "example",
                "sentence": "The girl who sits next to me is smart.",
                "highlight": "who sits next to me"
              },
              {
                "type": "example",
                "sentence": "The people who live next door are Canadian.",
                "highlight": "who live next door"
              },
              {
                "type": "example",
                "sentence": "Akira is the student who plays in a musical group.",
                "highlight": "who plays in a musical group"
              }
            ]
          },
          {
            "id": "practice",
            "label": "Practice",
            "title": "Build one sentence.",
            "blocks": [
              {
                "type": "combineSentences",
                "prompt": [
                  "My mom is a baker.",
                  "She makes delicious cakes."
                ],
                "answer": "My mom is a baker who makes delicious cakes."
              },
              {
                "type": "completeSentence",
                "prompt": "A teacher is a person ____ helps students learn.",
                "answer": "who"
              }
            ]
          }
        ]
      },
      "japanese": {
        "title": "who\u3092\u4f7f\u3063\u3066\u4eba\u3092\u8aac\u660e\u3059\u308b",
        "rule": "\u4eba\u306b\u3064\u3044\u3066\u3001\u3082\u3063\u3068\u304f\u308f\u3057\u3044\u60c5\u5831\u3092\u8db3\u3059\u3068\u304d\u306bwho\u3092\u4f7f\u3044\u307e\u3059\u3002",
        "pattern": "\u4eba + who + \u52d5\u8a5e\u306e\u307e\u3068\u307e\u308a",
        "needsReview": false
      },
      "examples": [
        {
          "sentence": "I have a classmate who likes math.",
          "highlight": "who likes math"
        },
        {
          "sentence": "Mateo has two friends who play basketball.",
          "highlight": "who play basketball"
        },
        {
          "sentence": "The girl who sits next to me is smart.",
          "highlight": "who sits next to me"
        },
        {
          "sentence": "The people who live next door are Canadian.",
          "highlight": "who live next door"
        }
      ],
      "workbookActivities": [
        {
          "number": 1,
          "type": "complete",
          "instruction": "Complete the sentences with who where it is necessary. If who is not necessary, write X."
        },
        {
          "number": 2,
          "type": "rewrite",
          "instruction": "Rewrite as one sentence."
        },
        {
          "number": 3,
          "type": "write",
          "instruction": "Write a sentence about each student's interests."
        },
        {
          "number": 4,
          "type": "complete",
          "instruction": "Complete the sentences. Use who."
        },
        {
          "number": 5,
          "type": "write",
          "instruction": "Write about two people. Use who and a word from the box."
        }
      ],
      "tags": [
        "grammar",
