    {
      "id": "ow_l4_u8_g2_direct_indirect_objects",
      "type": "grammar",
      "subject": "english",
      "course": "our-world",
      "level": 4,
      "unit": 8,
      "component": "grammar-2",
      "lessonId": "ow-l4-u8-grammar-2",
      "lessonStatus": "draft",
      "tag": "OW4-U8-G2",
      "title": "Direct and indirect objects",
      "shortName": "give someone something",
      "rule": "Use object pronouns to say who receives something and what they receive.",
      "pattern": "subject + verb + object pronoun + thing",
      "chart": {
        "chartType": "grammar-reference-card",
        "tabs": [
          {
            "id": "notice",
            "label": "Notice",
            "title": "Two sentence patterns can mean the same thing.",
            "blocks": [
              {
                "type": "equivalentSentences",
                "sentences": [
                  "Sara gave me the pencil.",
                  "Sara gave the pencil to me."
                ]
              },
              {
                "type": "equivalentSentences",
                "sentences": [
                  "My brother made us breakfast.",
                  "My brother made breakfast for us."
                ]
              }
            ]
          },
          {
            "id": "pattern",
            "label": "Pattern",
            "title": "Use to or for depending on the verb.",
            "blocks": [
              {
                "type": "pronounList",
                "label": "Object pronouns",
                "items": [
                  "me",
                  "you",
                  "her",
                  "him",
                  "us",
                  "them"
                ]
              },
              {
                "type": "pattern",
                "parts": [
                  "subject",
                  "gave / showed / sent / sold",
                  "person",
                  "thing"
                ]
              },
              {
                "type": "pattern",
                "parts": [
                  "subject",
                  "made / bought",
                  "thing",
                  "for + person"
                ]
              }
            ]
          },
          {
            "id": "examples",
            "label": "Examples",
            "title": "Workbook examples",
            "blocks": [
              {
                "type": "example",
                "sentence": "She gave me her games.",
                "highlight": "me her games"
              },
              {
                "type": "example",
                "sentence": "I sent them two games.",
                "highlight": "them two games"
              },
              {
                "type": "example",
                "sentence": "Lea made her a birthday card.",
                "highlight": "her a birthday card"
              }
            ]
          },
          {
            "id": "practice",
            "label": "Practice",
            "title": "Rewrite with an object pronoun.",
            "blocks": [
              {
                "type": "rewrite",
                "prompt": "My friends bought a dinosaur for Monica.",
                "answer": "My friends bought her a dinosaur."
              },
              {
                "type": "rewrite",
                "prompt": "She showed the photo to her friends.",
                "answer": "She showed them the photo."
              }
            ]
          }
        ]
      },
      "japanese": {
        "title": "\u76f4\u63a5\u76ee\u7684\u8a9e\u3068\u9593\u63a5\u76ee\u7684\u8a9e",
        "rule": "\u3060\u308c\u304c\u53d7\u3051\u53d6\u308b\u306e\u304b\u3001\u4f55\u3092\u53d7\u3051\u53d6\u308b\u306e\u304b\u3092\u8a00\u3046\u6587\u3067\u3059\u3002me, her, him, us, them\u306a\u3069\u3092\u4f7f\u3044\u307e\u3059\u3002",
        "pattern": "\u4e3b\u8a9e + \u52d5\u8a5e + \u4eba + \u7269",
        "needsReview": false
      },
      "examples": [
        {
          "sentence": "Sara gave me the pencil.",
          "highlight": "me the pencil"
        },
        {
          "sentence": "Sara gave the pencil to me.",
          "highlight": "to me"
        },
        {
          "sentence": "My brother made us breakfast.",
          "highlight": "us breakfast"
        },
        {
          "sentence": "My brother made breakfast for us.",
          "highlight": "for us"
        }
      ],
      "workbookActivities": [
        {
          "number": 1,
          "type": "match",
          "instruction": "Match the sentences with the same meaning."
        },
        {
          "number": 2,
          "type": "replace",
          "instruction": "Replace the underlined words with object pronouns."
        },
        {
          "number": 3,
          "type": "rewrite",
          "instruction": "Rewrite the sentences. Use her, them, and us."
        },
        {
          "number": 4,
          "type": "rewrite",
          "instruction": "Rewrite each sentence from Activity 3. Use to or for."
        },
        {
          "number": 5,
          "type": "write",
          "instruction": "Answer the questions."
        }
      ],
      "tags": [
        "grammar",
        "direct-object",
